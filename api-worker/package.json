{
  "name": "parseotter-api-worker",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dry-run:dev": "wrangler deploy --dry-run --env=\"\"",
    "dry-run:production": "wrangler deploy --dry-run --env production",
    "deploy:dev": "wrangler deploy --minify --env=\"\"",
    "deploy:production": "wrangler deploy --minify --env production",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest run",
    "test:stage1": "vitest run tests/app tests/security",
    "test:stage2": "vitest run tests/tasks tests/app/tasks.routes.spec.ts tests/app/expired-cleanup.spec.ts",
    "test:stage4": "vitest run tests/app/modal-dispatch-callback.routes.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.87.0"
  }
}
