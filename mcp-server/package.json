{
  "name": "@parseotter/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for ParseOtter PDF/EPUB to Markdown conversion",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "parseotter-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "clean": "rm -rf build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pdf",
    "epub",
    "markdown",
    "conversion",
    "parseotter"
  ],
  "author": "ParseOtter",
  "license": "AGPL-3.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
