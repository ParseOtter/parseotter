# Replace all values with your own configuration.
# Copy this file to .cloudflare-dispatch-secrets.env and fill the values locally.
# Do not commit the filled .cloudflare-dispatch-secrets.env file.

# R2 S3 API credentials from Cloudflare R2 API token creation.
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# Replace these placeholders with your own Cloudflare R2 target.
CLOUDFLARE_R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_R2_BUCKET_NAME=parseotter-files-dev
CLOUDFLARE_R2_ENDPOINT_URL=https://your-cloudflare-account-id.r2.cloudflarestorage.com

# Must match the Cloudflare Worker secrets for the same environment.
API_SECRET=<same-as-worker-MODAL_DISPATCH_API_KEY>
MODAL_CALLBACK_HMAC_SECRET=<same-as-worker-MODAL_CALLBACK_HMAC_SECRET>

# Optional internal callback bearer value. Leave blank unless you enable that path.
CALLBACK_INTERNAL_API_KEY=
